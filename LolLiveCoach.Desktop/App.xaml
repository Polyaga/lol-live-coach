<Application x:Class="LolLiveCoach.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose"
             StartupUri="Views/Shell/MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B1020" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#243042" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4F9CF9" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="TextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8" />
    </Application.Resources>
</Application>
