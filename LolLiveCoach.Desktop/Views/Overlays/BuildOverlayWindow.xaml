<Window x:Class="LolLiveCoach.Desktop.BuildOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="390"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{StaticResource TextBrush}"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Topmost="True"
        WindowStyle="None">
    <Border Padding="12"
            CornerRadius="18"
            Background="#E60D1725"
            BorderBrush="#CC4F9CF9"
            BorderThickness="0.9">
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Text="Build focus" />
                <TextBlock Grid.Column="1"
                           FontSize="10"
                           Foreground="{StaticResource MutedBrush}"
                           Text="Tab pour glisser" />
            </Grid>

            <TextBlock x:Name="BuildTitleText"
                       Margin="0,8,0,0"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Text="Ajustements de stuff" />

            <TextBlock x:Name="BuildSubtitleText"
                       Margin="0,4,0,0"
                       FontSize="11.5"
                       Foreground="{StaticResource MutedBrush}"
                       Text="Lecture du draft, des items allies et ennemis." />

            <ItemsControl x:Name="BuildTipsItemsControl"
                          Margin="0,10,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Padding="10"
                                CornerRadius="12"
                                Background="#141E30"
                                BorderBrush="#253249"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="54" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="42"
                                        Height="42"
                                        VerticalAlignment="Top"
                                        CornerRadius="10"
                                        Background="#1B2A42"
                                        BorderBrush="#2E4A6F"
                                        BorderThickness="1">
                                    <Grid>
                                        <TextBlock Text="{Binding ShortName}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#D9E8FF" />
                                        <Image Source="{Binding IconUrl}"
                                               Stretch="UniformToFill" />
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock MaxWidth="220"
                                                   FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding ItemName}" />
                                        <Border Margin="8,0,0,0"
                                                Padding="8,3"
                                                CornerRadius="999"
                                                Background="#1A2940"
                                                BorderBrush="#2A4668"
                                                BorderThickness="1"
                                                DockPanel.Dock="Right">
                                            <TextBlock FontSize="10.5"
                                                       Foreground="#D5E9FF"
                                                       Text="{Binding Category}" />
                                        </Border>
                                    </DockPanel>

                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="11.5"
                                               TextWrapping="Wrap"
                                               Text="{Binding Reason}" />

                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding PurchaseHint}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
